# ──────────────────────────────
# 의존성 / 빌드 산출물
# ──────────────────────────────
node_modules/
dist/
dist-ssr/
dist*/
build/
.vite/
.turbo/
.cache/

# Vite 임시 timestamp 파일
vite.config.ts.timestamp-*
vite.config.js.timestamp-*

# ──────────────────────────────
# 패키지 매니저 캐시 / lock 충돌 방지용 보조
# ──────────────────────────────
.npm/
.yarn/
.pnp.*
.pnpm-store/

# ──────────────────────────────
# 로그 / 디버그
# ──────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ──────────────────────────────
# 환경 변수 (개인 비밀 키 등)
# ──────────────────────────────
.env
.env.local
.env.*.local
*.local

# ──────────────────────────────
# 테스트 / 커버리지
# ──────────────────────────────
coverage/
.nyc_output/

# ──────────────────────────────
# TypeScript 산출물
# ──────────────────────────────
*.tsbuildinfo

# ──────────────────────────────
# 에디터 / OS
# ──────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ──────────────────────────────
# 게임 / 미디어 임시 산출물 (혹시 추가될 경우 대비)
# ──────────────────────────────
*.tmp
*.bak
*.orig
